<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RootControl.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:RootControl"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:webview="using:Microsoft.UI.Xaml.Controls"
    mc:Ignorable="d"
    Title="RootControl">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowSpacing="12" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            x:Name="StateTitleText"
            Text="RootControl"
            FontSize="28"
            FontWeight="SemiBold" />

        <TextBlock
            x:Name="StateDescriptionText"
            Grid.Row="1"
            Text="Etat de l'application"
            TextWrapping="WrapWholeWords" />

        <StackPanel
            x:Name="ActionPanel"
            Grid.Row="2"
            Orientation="Horizontal"
            Spacing="12"
            Visibility="Collapsed">

            <Button
                x:Name="OpenSettingsButton"
                Content="Parametres"
                Click="OpenSettingsButton_Click" />
        </StackPanel>

        <StackPanel
            x:Name="SettingsPanel"
            Grid.Row="3"
            Spacing="12"
            MaxWidth="520">

            <TextBlock Text="Lien a afficher" />
            <TextBox
                x:Name="WebUrlTextBox"
                PlaceholderText="https://exemple.local" />

            <TextBlock Text="Nouveau PIN maitre" />
            <PasswordBox x:Name="MasterPinBox" />

            <TextBlock Text="Repeter le PIN maitre" />
            <PasswordBox x:Name="ConfirmMasterPinBox" />

            <CheckBox
                x:Name="RefreshEnabledCheckBox"
                Content="Activer le rafraichissement automatique" />

            <TextBlock Text="Duree avant rafraichissement (hh:mm)" />
            <TextBox
                x:Name="RefreshIntervalTextBox"
                Text="00:15"
                PlaceholderText="00:15" />

            <CheckBox
                x:Name="RefreshOnIdleOnlyCheckBox"
                Content="Rafraichir uniquement en cas d'inactivite" />

            <TextBlock Text="Duree d'inactivite avant rafraichissement (hh:mm)" />
            <TextBox
                x:Name="IdleRefreshDelayTextBox"
                Text="00:05"
                PlaceholderText="00:05" />

            <CheckBox
                x:Name="ForceHardRefreshCheckBox"
                Content="Forcer le hard refresh" />

            <CheckBox
                x:Name="BlockInputsCheckBox"
                Content="Bloquer clavier et souris" />

            <Button
                x:Name="SaveSettingsButton"
                Content="Enregistrer la configuration"
                Click="SaveSettingsButton_Click" />

            <TextBlock
                x:Name="SettingsFeedbackText"
                Text=""
                TextWrapping="WrapWholeWords" />
        </StackPanel>

        <webview:WebView2
            x:Name="BrowserView"
            Grid.Row="5"
            Source="https://example.com"
            Visibility="Collapsed" />
    </Grid>
</Window>
